# Auth
NEXTAUTH_SECRET=replace-with-random-string
NEXTAUTH_URL=https://your-domain.com

# Database (SQLite, persisted via ./data volume)
DATABASE_URL=file:/app/data/data.db

# Uploads (persisted via ./uploads volume)
UPLOAD_DIR=./public/uploads

# Bootstrap admin (used by prisma seed if you run it manually)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=ChangeMe123!

# Compose runtime
IMAGE_TAG=latest
APP_PORT=3000
