# Auth (Auth.js v5 reads AUTH_SECRET; NEXTAUTH_* kept for compatibility)
AUTH_SECRET=replace-with-random-string
NEXTAUTH_SECRET=replace-with-random-string
NEXTAUTH_URL=https://your-domain.com
AUTH_TRUST_HOST=true
# Do NOT set AUTH_URL — use NEXTAUTH_URL (site root, not /api/auth)

# Server Actions: same value at image build time AND container runtime
# Generate: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-base64-aes-key

# Database (SQLite, persisted via ./data volume)
DATABASE_URL=file:/app/data/data.db

# Uploads (persisted via ./data volume, alongside SQLite)
UPLOAD_DIR=./data/uploads

# Bootstrap admin (used by prisma seed if you run it manually)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=ChangeMe123!

# Compose runtime
IMAGE_TAG=latest
APP_PORT=3000
