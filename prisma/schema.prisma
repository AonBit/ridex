generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SiteConfig {
  id               Int         @id @default(1)
  companyName      String
  companyTagline   String
  contactPhone     String
  contactEmail     String
  whatsapp         String?
  address          String
  businessHours    String
  logoPath         String?
  faviconPath      String?
  rentCtaType      RentCtaType @default(phone)
  rentCtaTarget    String?
  footerCopyright  String
  legalNotice      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model ThemeConfig {
  id              Int      @id @default(1)
  primaryColor    String
  secondaryColor  String
  accentColor     String
  backgroundColor String
  surfaceColor    String
  textColor       String
  successColor    String
  warningColor    String
  errorColor      String
  borderRadius    String
  shadowStyle     String
  fontHeading     String
  fontBody        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PageContent {
  id                    Int      @id @default(1)
  heroTitle             String
  heroSubtitle          String
  heroCtaText           String
  heroCtaLink           String
  sectionFeaturedTitle  String
  sectionWhyUsTitle     String
  sectionBlogTitle      String
  sectionFaqTitle       String
  showWhyUs             Boolean  @default(true)
  showTestimonials      Boolean  @default(true)
  showFaq               Boolean  @default(true)
  showBlog              Boolean  @default(true)
  seoTitle              String
  seoDescription        String
  ogImagePath           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model WhyUsItem {
  id        String   @id @default(cuid())
  title     String
  body      String
  icon      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FleetCar {
  id              String   @id @default(cuid())
  name            String
  brand           String
  year            Int
  seats           Int
  fuelType        String
  transmission    String
  priceLabel      String
  mileageLabel    String
  coverImagePath  String
  fieldVisibility Json?
  isPublished     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  body        String
  coverPath   String?
  isPublished Boolean  @default(true)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NavItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  type      NavType  @default(INTERNAL)
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id         String   @id @default(cuid())
  path       String   @unique
  fileName   String
  mimeType   String
  size       Int
  usedBy     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  locale    Locale   @default(ja)
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LocalizedText {
  id        String   @id @default(cuid())
  key       String
  locale    Locale
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
}

model LegalPage {
  id          String           @id @default(cuid())
  slug        String
  locale      Locale
  title       String
  contentType LegalContentType @default(TEXT)
  content     String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([slug, locale])
}

model CompanyInfo {
  id               String   @id @default(cuid())
  locale           Locale   @unique
  companyName      String
  representative   String
  registrationNo   String
  postalCode       String
  address          String
  phone            String
  email            String
  businessHours    String
  supportHours     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum UserRole {
  OWNER
  EDITOR
}

enum NavType {
  INTERNAL
  EXTERNAL
}

enum Locale {
  ja
  en
  zh_Hant
}

enum LegalContentType {
  TEXT
  MARKDOWN
}

enum RentCtaType {
  phone
  email
  whatsapp
  url
}
